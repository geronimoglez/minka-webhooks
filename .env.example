# Copy to .env.local for `vercel dev`. Set in Vercel dashboard for prod.
#
# GHL purgado 2026-07-16 (decisión Gerónimo): se salió de GoHighLevel. Las vars GHL_*,
# WEBHOOK_SHARED_SECRET, NOTION_* y OPENCLAW_* ya no las usa ningún endpoint (vivían en el
# webhook /api/ghl, ahora borrado) → BÓRRALAS del env de Vercel. El PIT token GHL, además,
# conviene REVOCARLO en GoHighLevel (daba acceso a la cuenta con los leads).

# --- Telegram (avisos internos a Gerónimo) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- LLM del diagnóstico P0 (/api/diagnostico) ---
OPENROUTER_API_KEY=
# DIAGNOSTICO_MODEL=xiaomi/mimo-v2.5-pro   # opcional; default en código

# --- CRM: Odoo (JSON-RPC) — usado por diagnostico / onboarding / portal-status vía lib/crm.js ---
# Driver auto: si ODOO_URL+ODOO_DB+ODOO_API_KEY están set → "odoo"; si no → "none" (degrada honesto).
# CRM_DRIVER=odoo            # opcional; fuerza el driver ("odoo" | "none")
ODOO_URL=
ODOO_DB=
ODOO_USER=
ODOO_API_KEY=
# Wake-retry para el cold-start de Railway (opcionales; defaults sensatos en lib/crm.js):
# ODOO_WAKE_RETRIES=2
# ODOO_WAKE_BACKOFF_MS=1500
# ODOO_WAKE_MAX_MS=6000
