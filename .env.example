# Copy to .env.local for vercel dev. Set in Vercel dashboard for prod.

# Validates the X-Webhook-Signature header GHL sends (recommended).
WEBHOOK_SHARED_SECRET=

# Notion log (optional)
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# openclaw forward (optional, for implementacion_arranca events)
OPENCLAW_WEBHOOK_URL=
OPENCLAW_GATEWAY_TOKEN=

# --- For /api/precalifica endpoint ---
# GHL Sub-account PIT token (different from the webhook secret above)
GHL_TOKEN_LOCATION=pit-xxxxxxxx
